# Defaults do runner (lado HOST — lido pelo run.sh ANTES do env -i).
# Forma `: "${VAR:=value}"` → quem exportar a variável ANTES de chamar o run.sh
# vence este default. Formato sourced por bash (stdlib-only, sem YAML).

# --- Esforço e raciocínio: SEMPRE explícitos, nunca herdados (V17) ---
: "${EFFORT_PINNED:=high}"
: "${THINKING_PINNED:=8000}"

# --- Limites de execução da Trilha B (§6.3) ---
: "${MAX_TURNS:=30}"
: "${BUDGET_PER_CASE_USD:=2.00}"
: "${TIMEOUT_S:=900}"

# --- Proxy de verdade-base (§4.4) ---
: "${PROXY_HOST:=127.0.0.1}"
: "${PROXY_PORT:=8787}"
: "${PROXY_UPSTREAM:=https://api.anthropic.com}"
# Allowlist de hosts de destino (separados por espaço). Qualquer host fora
# desta lista que apareça no proxy.jsonl é sinalizado pela auditoria (B7).
: "${PROXY_ALLOWED_HOSTS:=api.anthropic.com}"

# --- Fonte de tarefas LEB (override se estiver noutro lugar) ---
: "${LEB_ROOT:=$HOME/x/AI-BENCHMARK}"

# --- Workspace vivo: FORA da árvore deste repo, de propósito ---
# Se ficasse em ./work, o CLAUDE.md da raiz deste repo contaminaria qualquer
# sessão iniciada abaixo dele (a auditoria A3 rejeitaria — e com razão). Por
# isso o default é /tmp, cuja cadeia de diretórios-pai é limpa.
: "${WORK_ROOT:=${TMPDIR:-/tmp}/shvia-bench-work}"

# --- PATH extra pro processo sanitizado (ex.: onde o `claude` está) ---
# O env -i zera o PATH; o default do run.sh é /usr/local/bin:/usr/bin:/bin.
# Se o `claude`/`node` estiver noutro lugar (~/.local/bin, /opt/homebrew/bin),
# aponte aqui — caminhos separados por ':'. Vazio = só o default.
: "${BENCH_EXTRA_PATH:=}"
